    - target: {fileID: 1095800419396250755, guid: 209f429283eef0a4bbe91d41c0d94daa, type: 3}
      propertyPath: titulo
      value: "\xC2ncora"
      objectReference: {fileID: 0}
    - target: {fileID: 1095800419396250755, guid: 209f429283eef0a4bbe91d41c0d94daa, type: 3}
      propertyPath: descricao
      value: "Esta \xE2ncora representa as embarca\xE7\xF5es ligadas ao Trapiche
        Santo \xC2ngelo. Navios mercantes conectam S\xE3o Lu\xEDs \xE0s rotas comerciais
        do Atl\xE2ntico. Por eles sa\xEDam algod\xE3o e outros produtos maranhenses
        para exporta\xE7\xE3o. Tamb\xE9m chegavam tecidos, azulejos e carv\xE3o mineral
        importados. A posi\xE7\xE3o do trapiche facilitava o embarque e desembarque
        de cargas. Isso fez dele pe\xE7a central da infraestrutura portu\xE1ria da
        cidade. Essas embarca\xE7\xF5es impulsionaram a economia e a moderniza\xE7\xE3o
        de S\xE3o Lu\xEDs."
      objectReference: {fileID: 0}
