--- !u!1001 &1161730634
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 4076170726315474803, guid: 9e8b9c6555caea54483bfca5f7675b5a, type: 3}
      propertyPath: titulo
      value: "Tijolo da Chamin\xE9"
      objectReference: {fileID: 0}
    - target: {fileID: 4076170726315474803, guid: 9e8b9c6555caea54483bfca5f7675b5a, type: 3}
      propertyPath: visual
      value: 
      objectReference: {fileID: 0}
    - target: {fileID: 4076170726315474803, guid: 9e8b9c6555caea54483bfca5f7675b5a, type: 3}
      propertyPath: descricao
      value: "Este tijolo pertence a uma das duas chamin\xE9s hist\xF3ricas do Trapiche
        Santo \xC2ngelo. No final do s\xE9culo XIX, elas eram essenciais para o funcionamento
        industrial do complexo. Integravam um sistema de caldeiras movidas a carv\xE3o
        que produzia vapor em alta press\xE3o. Esse vapor movimentava m\xE1quinas
        e prensas usadas no beneficiamento do algod\xE3o. As chamin\xE9s liberavam
        a fuma\xE7a e garantiam a circula\xE7\xE3o de ar das caldeiras. Mais do que
        estruturas arquitet\xF4nicas, eram parte da tecnologia mais avan\xE7ada da
        \xE9poca. Hoje, simbolizam a import\xE2ncia industrial e hist\xF3rica do
        Trapiche para S\xE3o Lu\xEDs."
      objectReference: {fileID: 0}
    - target: {fileID: 4076170726315474803, guid: 9e8b9c6555caea54483bfca5f7675b5a, type: 3}
      propertyPath: objetoVisual
      value: 
      objectReference: {fileID: 125321657}
